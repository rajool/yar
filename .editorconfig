# https://editorconfig.org
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

[*.py]
indent_size = 4

[*.swift]
indent_size = 4

[*.md]
# Trailing whitespace can be a meaningful hard line break in Markdown.
trim_trailing_whitespace = false

[Makefile]
indent_style = tab
